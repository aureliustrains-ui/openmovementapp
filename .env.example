# Copy to .env.local for local development. Never commit local secret env files.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
SESSION_SECRET=replace-with-a-long-random-secret
NODE_ENV=development
PORT=5000
SHUTDOWN_TIMEOUT_MS=10000

# Optional local one-off admin bootstrap
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Dev Admin

# Optional object storage for client video uploads (movement checks / progress reports)
# If unset, upload-url API will return "OBJECT_STORAGE_NOT_CONFIGURED" outside test mode.
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_UPLOAD_URL_TTL_SECONDS=900
OBJECT_STORAGE_READ_URL_TTL_SECONDS=3600
CLIENT_VIDEO_MAX_SIZE_MB=250
